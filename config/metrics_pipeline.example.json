{
  "_documentation": {
    "job_resolution": "When jobs[].module is omitted, Heimdallr resolves jobs[].name to heimdallr.metrics.jobs.<name>.",
    "job_addition": "To add a new job, create the module under heimdallr/metrics/jobs/ and declare it in jobs[]. Use jobs[].module only for non-conventional names inside heimdallr.metrics.jobs.",
    "parallel_execution": "Profiles may set execution.max_parallel_jobs. Jobs may declare needs to wait for prerequisite job names while still allowing independent jobs to run in parallel.",
    "segmentation_requirements": "Jobs should declare requires_segmentation_tasks so external requested_metrics_modules can avoid unnecessary TotalSegmentator tasks.",
    "inventory_requirements": "Automatic CT jobs should declare requires_inventory so the metrics worker only runs jobs compatible with the total segmentation inventory.",
    "experimental_jobs": "Experimental metrics modules should live under heimdallr.metrics.jobs.tests or heimdallr.metrics.analysis and be enabled only via explicit jobs[].module overrides in host-local config.",
    "secondary_capture_transfer_syntax": "Jobs that emit Secondary Capture DICOM may set secondary_capture_transfer_syntax to original, deflated, jpeg_ls_lossless, jpeg_2000_lossless, or rle_lossless. Head derived CT DICOM may set derived_ct_transfer_syntax with the same values."
  },
  "default_profile": "ct_automatic_metrics",
