# Heimdallr Environment Configuration Template
# Copy this file to .env and fill in your actual values

# TotalSegmentator License Key
# Get your license from: https://www.totalsegmentator.com/
TOTALSEGMENTATOR_LICENSE=your_license_key_here

# OpenAI API settings (used by medgemma_api.py for report generation/translation)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5

# Optional service overrides
MEDGEMMA_PORT=8004
MEDGEMMA_SERVICE_URL=http://localhost:8004/analyze
TOTALSEGMENTATOR_PORT=8005
TOTALSEGMENTATOR_SERVICE_URL=http://localhost:8005/process
