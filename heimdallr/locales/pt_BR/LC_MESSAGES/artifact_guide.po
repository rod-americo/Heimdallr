msgstr "[Placeholder] Inserir texto de laudo."

msgid "bone.report.normal"
msgstr "– atenuação trabecular de L1 de {value}, dentro dos limites esperados para densidade mineral óssea preservada."

msgid "bone.report.osteopenia"
msgstr "– atenuação trabecular de L1 de {value}, evidenciando redução da densidade mineral óssea, sugestiva de osteopenia."

msgid "bone.report.osteoporosis_suggestive"
msgstr "– atenuação trabecular de L1 de {value}, achado sugestivo de osteoporose."

msgid "bone.report.osteoporosis_marked"
msgstr "– atenuação trabecular de L1 de {value}, compatível com acentuada redução da densidade mineral óssea, sugestiva de osteoporose."

msgid "bone.report.osteoporosis_fragility"
msgstr "– atenuação trabecular de L1 de {value}, compatível com acentuada redução da densidade mineral óssea, sugestiva de osteoporose, associada a maior risco de fratura por fragilidade."

msgid "bone.references"
msgstr "JANG, Samuel et al. Opportunistic osteoporosis screening at routine abdominal and thoracic CT: normative L1 trabecular attenuation values in more than 20 000 adults. <i>Radiology</i>, v. 291, p. 360-367, 2019. DOI: 10.1148/radiol.2019181648."

msgid "l3.row.measure"
msgstr "Área muscular esquelética no corte axial selecionado ao nível de L3."

msgid "l3.row.delivery"
msgstr "DICOM Secondary Capture com corte axial principal e referência sagital do nível medido."

msgid "l3.row.reading"
msgstr "Usar o axial como imagem principal. O sagital serve para confirmar o nível anatômico."

