msgid "l3.row.practical_ranges_smi"
msgstr "L3 SMI (cm²/m²): women normal ≥ 39, sarcopenia < 39; men normal ≥ 50, sarcopenia < 50."

msgid "l3.row.practical_ranges_density"
msgstr "Muscle density (HU): normal > 40, reduced 30-40, marked myosteatosis < 30."

msgid "l3.row.bmi_adjustment.label"
msgstr "BMI adjustment"

msgid "l3.row.bmi_adjustment.value"
msgstr "When available: BMI < 25, abnormal density < 41 HU; BMI ≥ 25, abnormal density < 33 HU."

msgid "l3.row.bmi_adjustment.not_applicable"
msgstr "Not applicable when the selected series is contrast-enhanced."

msgid "l3.row.report_suggestions"
msgstr "Suggested report text"

msgid "l3.row.cautions"
msgstr "Missing, truncated, or inadequately segmented L3 may invalidate the measurement or reduce reliability."

msgid "l3.report.normal"
msgstr "– skeletal muscle at L3 with area and skeletal muscle index (SMI) within normal limits for sex.\n– preserved skeletal muscle at the L3 level, without tomographic criteria for sarcopenia."

msgid "l3.report.sarcopenia_only"
msgstr "– reduced skeletal muscle index (SMI) at the L3 level, compatible with sarcopenia.\n– skeletal muscle at L3 with SMI below the expected range for sex, compatible with sarcopenia.\n– SMI of {smi}, characterizing sarcopenia."

msgid "l3.report.sarcopenia_myosteatosis"
msgstr "– reduced SMI associated with decreased muscle attenuation, compatible with sarcopenia and myosteatosis.\n– skeletal muscle at L3 with low SMI and reduced density, compatible with sarcopenia associated with fatty infiltration.\n– SMI of {smi} and mean muscle density of {density}, characterizing sarcopenia associated with myosteatosis.\n– sarcopenia associated with myosteatosis."

msgid "l3.report.myosteatosis_only"
msgstr "– reduced muscle attenuation at the L3 level, compatible with myosteatosis.\n– skeletal muscle with decreased density (in HU), without significant SMI reduction, suggesting isolated myosteatosis.\n– mean muscle density of {density}, compatible with myosteatosis.\n– myosteatosis."

msgid "l3.report.neutral"
msgstr "– reduced skeletal muscle mass at the L3 level.\n– reduced muscle density, suggesting fatty infiltration."

msgid "l3.references"
msgstr "Prado, C. M. et al. Prevalence and clinical implications of sarcopenic obesity in patients with solid tumours of the respiratory and gastrointestinal tracts: a population-based study. <i>The Lancet Oncology</i>, v. 9, n. 7, p. 629-635, 2008.\nMartin, L. et al. Cancer cachexia in the age of obesity: skeletal muscle depletion is a powerful prognostic factor. <i>Journal of Clinical Oncology</i>, v. 31, n. 12, p. 1539-1547, 2013.\nAubrey, J. et al. Measurement of skeletal muscle radiation attenuation and basis of its biological variation. <i>Acta Physiologica</i>, v. 210, n. 3, p. 489-497, 2014."

