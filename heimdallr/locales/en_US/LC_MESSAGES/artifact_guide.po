msgid "bone.row.measure"
msgstr "L1 trabecular attenuation in HU on already acquired CT."

msgid "bone.row.delivery"
msgstr "Secondary Capture DICOM with sagittal L1 slice, trabecular ROI, and mean value."

msgid "bone.row.reading"
msgstr "Confirm L1, center the ROI in trabecular bone, and exclude relevant truncation."

msgid "bone.row.result"
msgstr "Mean value: {hu_mean} | Automated classification: {classification}"

msgid "bone.row.report_suggestion"
msgstr "Suggested report text"

msgid "bone.row.cautions"
msgstr "Incomplete mask, deformity, metal, or inadequate technique may reduce confidence."

msgid "bone.report.placeholder"
msgstr "[Placeholder] Insert report wording."

msgid "bone.report.normal"
msgstr "– L1 trabecular attenuation of {value}, within the expected limits for preserved bone mineral density."

msgid "bone.report.osteopenia"
msgstr "– L1 trabecular attenuation of {value}, showing reduced bone mineral density, suggestive of osteopenia."

msgid "bone.report.osteoporosis_suggestive"
msgstr "– L1 trabecular attenuation of {value}, suggestive of osteoporosis."

msgid "bone.report.osteoporosis_marked"
msgstr "– L1 trabecular attenuation of {value}, compatible with marked reduction in bone mineral density, suggestive of osteoporosis."

msgid "bone.report.osteoporosis_fragility"
msgstr "– L1 trabecular attenuation of {value}, compatible with marked reduction in bone mineral density, suggestive of osteoporosis and associated with higher fragility-fracture risk."

msgid "bone.references"
msgstr "Jang, S. et al. Opportunistic osteoporosis screening at routine abdominal and thoracic CT: normative L1 trabecular attenuation values in more than 20 000 adults. <i>Radiology</i>, v. 291, p. 360-367, 2019. DOI: 10.1148/radiol.2019181648."

msgid "l3.row.measure"
msgstr "Skeletal muscle area on the selected axial slice at the L3 level."

msgid "l3.row.delivery"
msgstr "Secondary Capture DICOM with the main axial slice and sagittal reference for the measured level."

msgid "l3.row.reading"
msgstr "Use the axial image as the primary display. The sagittal panel confirms the anatomical level."

